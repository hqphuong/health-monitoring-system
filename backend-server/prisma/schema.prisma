generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  user_id          String           @id @default(uuid()) @db.VarChar(50)
  email            String           @unique @db.VarChar(100)
  password         String?          @db.VarChar(100)
  created_at       DateTime?        @default(now())
  full_name        String           @default("Người dùng vô danh") @db.VarChar(100)
  otp_expires_at   DateTime?
  reset_otp        String?          @db.VarChar(6)
  verify_otp       String?          @db.VarChar(6)
  alert_logs       AlertLog[]
  devices          Device[]
  health_metrics   HealthMetric[]
  health_profile   HealthProfile?
  relatives        Relative[]
  workout_sessions WorkoutSession[]

  @@map("user")
}

model HealthProfile {
  profile_id   String    @id @default(uuid()) @db.VarChar(50)
  user_id      String    @unique @db.VarChar(50)
  height       Float?
  weight       Float?
  gender       String?   @db.VarChar(20)
  birth        DateTime? @db.Date
  systolic_bp  Int?
  diastolic_bp Int?
  updated_at   DateTime? @updatedAt
  blood_type   String?   @db.VarChar(10)
  phone_number String?   @db.VarChar(20)
  user         User      @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@map("health_profile")
}

model Relative {
  phone_num    String @db.VarChar(20)
  user_id      String @db.VarChar(50)
  contact_name String @db.VarChar(100)
  relationship String @db.VarChar(50)
  relative_id  String @id @default(dbgenerated("(gen_random_uuid())::character varying")) @db.VarChar(50)
  user         User   @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@map("relative")
}

model Device {
  device_id      String   @id @db.VarChar(50)
  user_id        String?  @db.VarChar(50)
  provider       String   @db.VarChar(50)
  status         String?  @db.VarChar(20)
  last_sync_time DateTime @default(now())
  user           User?    @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@map("device")
}

model WorkoutSession {
  work_id        String         @id @default(uuid()) @db.VarChar(50)
  user_id        String?        @db.VarChar(50)
  start_time     DateTime
  end_time       DateTime?
  max_heart_rate Int?
  av_heart_rate  Int?
  status         String?        @db.VarChar(20)
  alert_logs     AlertLog[]
  health_metrics HealthMetric[]
  user           User?          @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@map("workout_session")
}

model HealthMetric {
  health_id      String          @id @default(uuid()) @db.VarChar(50)
  user_id        String          @db.VarChar(50) // Fix: Bỏ dấu ? để đảm bảo Unique hoạt động chính xác
  work_id        String?         @db.VarChar(50)
  record_time    DateTime
  heart_rate     Int?
  steps          Int?
  sleep_duration Int?
  stress_level   Int?
  
  // --- CÁC TRƯỜNG BỔ SUNG ĐỂ ĐỒNG BỘ HEALTH CONNECT ---
  blood_oxygen   Float?          // Lưu SpO2 (%)
  calories       Float?          // Lưu năng lượng tiêu thụ (kcal)
  distance       Float?          // Lưu quãng đường (meters)
  // ---------------------------------------------------

  raw_data        Json?
  user            User           @relation(fields: [user_id], references: [user_id], onDelete: Cascade) // Fix: Bỏ dấu ?
  workout_session WorkoutSession? @relation(fields: [work_id], references: [work_id])

  // Chống trùng lặp dữ liệu: 1 người dùng không thể có 2 bản ghi tại cùng 1 thời điểm
  @@unique([user_id, record_time])
  @@map("health_metric")
}

model AlertLog {
  alert_id           String          @id @default(uuid()) @db.VarChar(50)
  user_id            String?         @db.VarChar(50)
  work_id            String?         @db.VarChar(50)
  type               String          @db.VarChar(50)
  trigger_heart_rate Int
  alert_time         DateTime
  is_sos_sent        Boolean?        @default(false)
  user               User?           @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  workout_session    WorkoutSession? @relation(fields: [work_id], references: [work_id])

  @@map("alert_log")
}